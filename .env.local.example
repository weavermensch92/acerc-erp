# Supabase 로컬 (`supabase start` 실행 후 출력값 복사)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 앱 URL (share 페이지 절대경로 생성에 사용)
NEXT_PUBLIC_APP_URL=http://localhost:3003

# Vercel Cron 보호 (프로덕션 only — 로컬은 비워둠)
# Vercel 대시보드 > Settings > Environment Variables 에 등록
# 등록 후 Vercel Cron 호출이 Authorization: Bearer <secret> 헤더 자동 포함
CRON_SECRET=
